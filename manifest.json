{
  "manifest_version": 3,
  "name": "LGE PDP Comparator",
  "version": "1.0.0",
  "description": "LGE.CO.KR PDP AS-IS / TO-BE 비교 검증 도구",
  "permissions": ["declarativeNetRequest","declarativeNetRequestWithHostAccess","scripting","tabs","storage","webRequest"],
  "host_permissions": ["https://*/*","http://*/*"],
  "background": { "service_worker": "background.js" },
  "declarative_net_request": {
    "rule_resources": [{ "id": "ruleset_1", "enabled": true, "path": "rules.json" }]
  },
  "action": { "default_title": "PDP Comparator", "default_popup": "popup.html" },
  "content_scripts": [{ "matches": ["https://*/*","http://*/*"], "js": ["content.js"], "all_frames": true, "run_at": "document_start" }],
  "web_accessible_resources": [{ "resources": ["compare.html", "mobile-override.js"], "matches": ["<all_urls>"] }]
}
